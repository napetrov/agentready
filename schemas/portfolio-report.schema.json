{
  "$id": "https://napetrov.github.io/agentready/schemas/v0.3.0/portfolio-report.schema.json",
  "title": "AgentReady portfolio (multi-repo) scan report",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "generatedAt": {
      "type": "string"
    },
    "repos": {
      "type": "array",
      "items": {
        "oneOf": [
          {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "ok": {
                "type": "boolean",
                "const": true
              },
              "score": {
                "type": "integer",
                "minimum": 0,
                "maximum": 100
              },
              "findingCount": {
                "type": "integer",
                "minimum": 0,
                "maximum": 9007199254740991
              },
              "bySeverity": {
                "type": "object",
                "properties": {
                  "info": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "warning": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  },
                  "error": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 9007199254740991
                  }
                },
                "required": [
                  "info",
                  "warning",
                  "error"
                ],
                "additionalProperties": false
              },
              "topFindings": {
                "type": "array",
                "items": {
                  "type": "object",
                  "properties": {
                    "id": {
                      "type": "string",
                      "minLength": 1
                    },
                    "title": {
                      "type": "string",
                      "minLength": 1
                    },
                    "severity": {
                      "type": "string",
                      "enum": [
                        "info",
                        "warning",
                        "error"
                      ]
                    },
                    "path": {
                      "type": "string"
                    },
                    "recommendation": {
                      "type": "string",
                      "minLength": 1
                    },
                    "confidence": {
                      "type": "string",
                      "enum": [
                        "low",
                        "medium",
                        "high"
                      ]
                    },
                    "scope": {
                      "type": "string",
                      "enum": [
                        "root",
                        "package",
                        "path",
                        "advisory"
                      ]
                    }
                  },
                  "required": [
                    "id",
                    "title",
                    "severity",
                    "recommendation"
                  ],
                  "additionalProperties": false
                }
              },
              "experimentalFindingFields": {
                "type": "array",
                "items": {
                  "type": "string",
                  "enum": [
                    "confidence",
                    "scope"
                  ]
                }
              }
            },
            "required": [
              "path",
              "ok",
              "score",
              "findingCount",
              "bySeverity",
              "topFindings"
            ],
            "additionalProperties": false
          },
          {
            "type": "object",
            "properties": {
              "path": {
                "type": "string"
              },
              "ok": {
                "type": "boolean",
                "const": false
              },
              "error": {
                "type": "string"
              }
            },
            "required": [
              "path",
              "ok",
              "error"
            ],
            "additionalProperties": false
          }
        ]
      }
    },
    "summary": {
      "type": "object",
      "properties": {
        "repoCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "scannedCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "scanErrorCount": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "averageScore": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "minScore": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "maxScore": {
          "anyOf": [
            {
              "type": "integer",
              "minimum": 0,
              "maximum": 100
            },
            {
              "type": "null"
            }
          ]
        },
        "totalFindings": {
          "type": "integer",
          "minimum": 0,
          "maximum": 9007199254740991
        },
        "bySeverity": {
          "type": "object",
          "properties": {
            "info": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "warning": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            },
            "error": {
              "type": "integer",
              "minimum": 0,
              "maximum": 9007199254740991
            }
          },
          "required": [
            "info",
            "warning",
            "error"
          ],
          "additionalProperties": false
        }
      },
      "required": [
        "repoCount",
        "scannedCount",
        "scanErrorCount",
        "averageScore",
        "minScore",
        "maxScore",
        "totalFindings",
        "bySeverity"
      ],
      "additionalProperties": false
    }
  },
  "required": [
    "generatedAt",
    "repos",
    "summary"
  ],
  "additionalProperties": false
}
