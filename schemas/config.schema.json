{
  "$id": "https://napetrov.github.io/agentready/schemas/v0.3.0/config.schema.json",
  "title": "AgentReady configuration",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "ignorePaths": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "largeFileWarningBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "largeFileErrorBytes": {
      "type": "integer",
      "minimum": 0,
      "maximum": 9007199254740991
    },
    "allowMinifiedFiles": {
      "type": "boolean"
    },
    "errorOnWarnings": {
      "type": "boolean"
    }
  },
  "additionalProperties": false
}
