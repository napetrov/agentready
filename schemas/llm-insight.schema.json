{
  "$id": "https://napetrov.github.io/agentready/schemas/v0.1.0/llm-insight.schema.json",
  "title": "AgentReady LLM insight",
  "$schema": "http://json-schema.org/draft-07/schema#",
  "type": "object",
  "properties": {
    "id": {
      "type": "string",
      "minLength": 1
    },
    "kind": {
      "type": "string",
      "enum": [
        "false-positive",
        "quality",
        "contradiction",
        "remediation",
        "note"
      ]
    },
    "findingId": {
      "type": "string",
      "minLength": 1
    },
    "target": {
      "type": "string",
      "minLength": 1
    },
    "verdict": {
      "type": "string",
      "minLength": 1
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "rationale": {
      "type": "string",
      "minLength": 1
    },
    "remediation": {
      "type": "string",
      "minLength": 1
    },
    "scoreImpact": {
      "type": "number"
    },
    "model": {
      "type": "string",
      "minLength": 1
    },
    "promptVersion": {
      "type": "string",
      "minLength": 1
    }
  },
  "required": [
    "id",
    "kind",
    "verdict",
    "confidence",
    "rationale",
    "model",
    "promptVersion"
  ],
  "additionalProperties": false
}
